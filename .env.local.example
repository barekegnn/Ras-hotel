# ============================================================
# Ras Hotel — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Find these in your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...   # Server-side only — never expose to browser

# ── Chapa Payment Gateway ─────────────────────────────────────
# https://developer.chapa.co/docs
CHAPA_SECRET_KEY=CHASECK_TEST-...        # Use TEST key in development
CHAPA_WEBHOOK_SECRET=your-webhook-secret # Set in Chapa dashboard → Webhooks
NEXT_PUBLIC_CHAPA_PUBLIC_KEY=CHAPUBK_TEST-...

# ── Africa's Talking SMS ──────────────────────────────────────
# https://developers.africastalking.com
AFRICASTALKING_API_KEY=your-api-key
AFRICASTALKING_USERNAME=your-username   # Use "sandbox" for testing
AFRICASTALKING_SENDER_ID=RasHotel       # Must be registered with AT

# ── Google AI (Gemini + Embeddings) ──────────────────────────
# https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy...
# Model identifiers (defaults shown — override if needed)
GEMINI_MODEL=gemini-2.5-flash-preview-04-17
EMBEDDINGS_MODEL=text-embedding-004

# ── Google Maps ───────────────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSy...

# ── Application ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000   # Production: https://rashotel.com
NEXT_PUBLIC_DEFAULT_LOCALE=en

# ── Supabase Edge Functions (populated automatically by Supabase) ─
# These are injected at runtime — you typically do not set these manually
# SUPABASE_URL  (same as NEXT_PUBLIC_SUPABASE_URL)
# SUPABASE_ANON_KEY
# SUPABASE_SERVICE_ROLE_KEY

# ── Cron Jobs ─────────────────────────────────────────────────
# Secret used to authenticate cron job requests (Vercel Cron or external scheduler)
# Set this to a long random string. Must match the Authorization: Bearer <secret> header.
CRON_SECRET=your-cron-secret-here

# ── Optional: Error Tracking ──────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=...
